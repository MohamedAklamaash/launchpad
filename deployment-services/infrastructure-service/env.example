DATABASE_USER_NAME=your_db_user
DATABASE_PASSWORD=your_db_password
DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_NAME=infrastructure_db
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=false
INFRASTRUCTURE_DB_URL=postgres://user:password@localhost:5433/infrastructure_db?ssl_mode=disable

RABBITMQ_URL=amqp://guest:guest@localhost:5672/

DJANGO_SECRET=your-secret-key-min-50-characters-long-change-this-in-production
JWT_SECRET=your-jwt-secret-min-32-characters
DJANGO_PORT=8002
RUN_MAIN=true
INTERNAL_API_TOKEN=your-internal-api-token-min-32-characters

# Database Connection Pool
DB_CONN_MAX_AGE=600

# AWS Credentials (Platform IAM User)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=3

DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

AWS_MAX_RETRY_ATTEMPTS=10
AWS_RETRY_MODE=adaptive
AWS_CONNECT_TIMEOUT=10
AWS_READ_TIMEOUT=60
