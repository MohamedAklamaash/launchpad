{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "module": "ESNext",
        "moduleResolution": "bundler",
        "rootDir": "src",
        "outDir": "dist",
        "composite": false,
        "tsBuildInfoFile": "dist/tsconfig.tsbuildinfo",
        "baseUrl": "./",
        "paths": {
            "@/*": [
                "src/*"
            ]
        }
    },
    "include": [
        "src"
    ],
}